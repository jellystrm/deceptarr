# Copy file này thành .env rồi điền thông tin thực
# cp .env.example .env

# User/group ID — chạy lệnh: id $USER
PUID=1000
PGID=1000
TZ=Asia/Ho_Chi_Minh

# TMDB API key — bắt buộc để expand season và resolve tên phim
# Lấy miễn phí tại: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Các cài đặt tùy chọn (mặc định đã tối ưu)
# SERVER_LABELS=ViệtSub,Lồng Tiếng
# DEFAULT_OUTPUT_MODE=strm
# EXPOSE_BOTH_MODES=false
# DOWNLOAD_CONTAINER=mkv
# POLL_INTERVAL_SECONDS=300
# LOG_LEVEL=INFO
# UI_PORT=8765