# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Download client (qBittorrent) ─────────────────────────────────────────────
# Default credentials match a fresh qBittorrent install.
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ── Torznab indexer ───────────────────────────────────────────────────────────
# Auto-generated on first start. Set here to keep stable across restarts.
TORZNAB_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# URL Radarr/Sonarr use to reach Deceptarr's Torznab endpoint.
# Auto-detected from service hostnames when not set.
PUBLIC_BASE_URL=http://deceptarr:8765

# UI listen port (must match the port in docker-compose ports:).
UI_PORT=8765

# ── All other settings are configured via the web UI ─────────────────────────
# TMDB API Key, Radarr/Sonarr/Jellyfin API keys, source order, output mode, etc.
# Open http://<host>:8765 after first start to configure.
